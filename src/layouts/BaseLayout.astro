---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  pubDate?: string;
  isArticle?: boolean;
  noindex?: boolean;
  dateModified?: string;
  author?: string;
  articleImage?: string;
}
const {
  title = 'AI Tools Pro',
  description = 'Practical comparisons, workflows, and buying guides for AI tools used by marketers, creators, and automation teams.',
  canonicalURL: canonicalURLProp,
  pubDate,
  isArticle = false,
  noindex = false,
  dateModified,
  author,
  articleImage,
} = Astro.props;

const siteName = 'AI Tools Pro';
const siteURL = 'https://ai.toolrouteai.com';
const networkName = 'ToolRoute AI';
const networkURL = 'https://toolrouteai.com';
const siteSlug = 'ai-tools-pro';

// Locale-aware nav links
const isZhCn = Astro.url.pathname.startsWith('/zh-cn/');
const localePrefix = isZhCn ? '/zh-cn' : '';

// i18n logic
const { pathname } = Astro.url;
const lang = pathname.startsWith('/zh-cn') ? 'zh-cn' : 'en';
const ui = isZhCn
  ? {
      reviews: '评测',
      tools: '工具',
      about: '关于',
      authors: '作者',
      tags: '标签',
      search: '搜索',
      footer: 'ToolRoute AI 的独立指南，帮你判断软件、自动化、PKM 和远程办公工具是否值得用。',
      contact: '联系',
      privacy: '隐私',
      terms: '条款',
      affiliate: '联盟披露',
      editorial: '编辑政策',
      allPosts: '全部文章',
      freeTools: '免费 AI 工具 →',
      cookieLead: '我们使用隐私友好的分析、广告脚本和联盟追踪来维持本站免费。继续浏览即表示你同意我们的',
      cookieAnd: '和',
      privacyPolicy: '隐私政策',
      accept: '同意',
    }
  : {
      reviews: 'Reviews',
      tools: 'Tools',
      about: 'About',
      authors: 'Authors',
      tags: 'Tags',
      search: 'Search',
      footer: 'Independent ToolRoute AI guides for software, automation, PKM, and remote-work decisions.',
      contact: 'Contact',
      privacy: 'Privacy',
      terms: 'Terms',
      affiliate: 'Affiliate Disclosure',
      editorial: 'Editorial Policy',
      allPosts: 'All Posts',
      freeTools: 'Free AI tools →',
      cookieLead: 'We use privacy-minded analytics, advertising scripts, and affiliate tracking to keep this site free. By continuing, you agree to our',
      cookieAnd: 'and',
      privacyPolicy: 'Privacy Policy',
      accept: 'Accept',
    };

// Force canonical to siteURL host regardless of which domain served the page.
const canonicalURL = canonicalURLProp ?? `${siteURL}${pathname}${Astro.url.search}`;
const isNetworkPage = canonicalURL.startsWith(`${networkURL}/`);
const displaySiteName = isNetworkPage ? networkName : siteName;
const displaySiteURL = isNetworkPage ? networkURL : siteURL;

const normalizedPath = pathname.replace(/^\/zh-cn/, '') || '/';
const pathWithTrailingSlash = normalizedPath.endsWith('/') ? normalizedPath : `${normalizedPath}/`;
const hasLocalizedStaticPage = new Set(['/', '/about/', '/contact/', '/privacy/', '/posts/', '/tools/']).has(pathWithTrailingSlash);
const hasLocalizedPostPage = /^\/posts\/[^/]+\/$/.test(pathWithTrailingSlash);
const hasLocalizedToolPage = /^\/tools\/[^/]+\/$/.test(pathWithTrailingSlash);
const shouldEmitLocalizedAlternates =
  !noindex && (hasLocalizedStaticPage || hasLocalizedPostPage || hasLocalizedToolPage);
const alternateEn = `${displaySiteURL}${pathWithTrailingSlash}`;
const alternateZh = `${displaySiteURL}${pathWithTrailingSlash === '/' ? '/zh-cn/' : `/zh-cn${pathWithTrailingSlash}`}`;

const ogImage = articleImage ? (articleImage.startsWith('http') ? articleImage : `${siteURL}${articleImage}`) : `${siteURL}/og-default.png`;
const cloudflareWebAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const hasCloudflareWebAnalyticsToken =
  typeof cloudflareWebAnalyticsToken === 'string' &&
  /^[0-9a-f]{32}$/i.test(cloudflareWebAnalyticsToken);
const adsensePublisherId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#7c3aed" />
    <meta name="color-scheme" content="light" />
    <meta name="google-site-verification" content="jVpIV2uq9S09WBugGVvxDvLrP3FDSoDdjGssxfJTN5M" />
    <meta name="description" content={description} />
    <link rel="icon" href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"><rect width="64" height="64" rx="12" fill="%231d4ed8"/><text x="32" y="42" text-anchor="middle" font-family="Arial" font-size="30" font-weight="700" fill="white">AI</text></svg>' />
    <title>{title}</title>
    {noindex && (<meta name="robots" content="noindex,follow" />)}

    {shouldEmitLocalizedAlternates && (
      <>
        <!-- i18n -->
        <link rel="alternate" hreflang="en" href={alternateEn} />
        <link rel="alternate" hreflang="zh-cn" href={alternateZh} />
        <link rel="alternate" hreflang="x-default" href={alternateEn} />
      </>
    )}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${displaySiteName} RSS Feed`} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={displaySiteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "datePublished": pubDate,
        "dateModified": dateModified ?? pubDate,
        "image": articleImage ?? ogImage,
        "inLanguage": lang,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL
        },
        "author": {
          "@type": "Person",
          "name": author ?? "Editorial Team",
          "url": `${siteURL}/about/`
        },
        "publisher": {
          "@type": "Organization",
          "name": displaySiteName,
          "url": displaySiteURL,
          "logo": {
            "@type": "ImageObject",
            "url": ogImage
          }
        }
      })} />
    )}


    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": displaySiteURL },
          { "@type": "ListItem", "position": 2, "name": "Posts", "item": `${displaySiteURL}/posts/` },
          { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
        ]
      })} />
    )}
    
    {!isArticle && Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": displaySiteName,
        "url": displaySiteURL,
        "description": description,
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${displaySiteURL}/search/?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      })} />
    )}

    {hasCloudflareWebAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareWebAnalyticsToken })}
      ></script>
    )}
    {adsensePublisherId && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsensePublisherId}`}
        crossorigin="anonymous"
      ></script>
    )}
    {adsensePublisherId && (
      <meta name="google-adsense-account" content={adsensePublisherId} />
    )}
    {ga4MeasurementId && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
    )}
    {ga4MeasurementId && (
      <script is:inline set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4MeasurementId}', { anonymize_ip: true });`} />
    )}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={isZhCn ? "/zh-cn/" : "/"}>{displaySiteName}</a>
      <nav>
        <a href={`${localePrefix}/posts/`}>{ui.reviews}</a>
        <a href={`${localePrefix}/tools/`}>{ui.tools}</a>
        <a href={`${localePrefix}/about/`}>{ui.about}</a>
        <a href="/authors/">{ui.authors}</a>
        <a href="/tags/">{ui.tags}</a>
        <a href="/search/">{ui.search}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>{ui.footer}</p>
      <form
        class="footer-subscribe"
        action="https://buttondown.com/api/emails/embed-subscribe/aitoolspro"
        method="post"
        target="popupwindow"
        aria-label="Subscribe to the weekly digest"
      >
        <input type="email" name="email" placeholder="Get the weekly digest" required />
        <input type="hidden" name="embed" value="1" />
        <button type="submit">Subscribe</button>
      </form>
      <nav class="footer-nav">
        <a href={`${localePrefix}/about/`}>{ui.about}</a>
        <a href={`${localePrefix}/contact/`}>{ui.contact}</a>
        <a href={`${localePrefix}/privacy/`}>{ui.privacy}</a>
        <a href="/terms/">{ui.terms}</a>
        <a href="/affiliate-disclosure/">{ui.affiliate}</a>
        <a href="/editorial-policy/">{ui.editorial}</a>
        <a href={`${localePrefix}/posts/`}>{ui.allPosts}</a>
        <a href="/authors/">{ui.authors}</a>
        <a href="/tags/">{ui.tags}</a>
        <a href="/rss.xml">RSS</a>
        <a
          href={`${localePrefix}/tools/`}
          style="display:inline-flex;align-items:center;gap:.4rem;font-size:.9rem;color:#7c3aed;text-decoration:none;"
        >
          {ui.freeTools}
        </a>
      </nav>
    </footer>
    <div id="cookie-consent" class="cookie-consent" hidden>
      <p>{ui.cookieLead} <a href={`${localePrefix}/privacy/`}>{ui.privacyPolicy}</a> {ui.cookieAnd} <a href="/terms/">{ui.terms}</a>.</p>
      <button type="button" id="cookie-consent-accept">{ui.accept}</button>
    </div>
    <script is:inline>
      (() => {
        const banner = document.getElementById('cookie-consent');
        const button = document.getElementById('cookie-consent-accept');
        if (!banner || !button) return;
        if (localStorage.getItem('cookie-consent-v1') === 'accepted') return;
        banner.hidden = false;
        button.addEventListener('click', () => {
          localStorage.setItem('cookie-consent-v1', 'accepted');
          banner.hidden = true;
        });
      })();
    </script>
  </body>
</html>
