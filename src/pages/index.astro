---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    name: 'AI Tools Pro',
    url: 'https://ai.toolrouteai.com',
    description: 'AI software reviews, local AI workflows, automation stacks, and practical comparisons for solo operators.',
    links: [
      ['Make.com vs Zapier for AI Automation', 'https://ai.toolrouteai.com/posts/make-com-vs-zapier-for-ai-automation/'],
      ['LM Studio vs Ollama for Local AI Development', 'https://ai.toolrouteai.com/posts/lm-studio-vs-ollama-for-local-ai-development/'],
      ['Best Offline AI Writing Tools for Deep Work', 'https://ai.toolrouteai.com/posts/best-offline-ai-writing-tools-for-deep-work/'],
    ],
  },
  {
    name: 'Home Office Gear',
    url: 'https://gear.toolrouteai.com',
    description: 'Ergonomic desk gear, creator lighting, monitor setups, and buying guides for healthier remote work.',
    links: [
      ['Quiet Mechanical Switches for Shared Home Office', 'https://gear.toolrouteai.com/posts/quiet-mechanical-switches-shared-home-office/'],
      ['Top Rated Monitor Risers With Storage Drawers', 'https://gear.toolrouteai.com/posts/top-rated-monitor-risers-with-storage-drawers/'],
      ['Manual vs Electric Standing Desk Longevity', 'https://gear.toolrouteai.com/posts/manual-vs-electric-standing-desk-longevity-2026/'],
    ],
  },
  {
    name: 'Notes Automate',
    url: 'https://notes-automate.com',
    description: 'Obsidian plugin guides, vault automation, note templates, and practical workflows for serious note takers.',
    links: [
      ['n8n Workflow for Obsidian Daily Notes Setup', 'https://notes-automate.com/posts/n8n-workflow-for-obsidian-daily-notes-setup/'],
      ['Obsidian Local REST API Configuration Script Tool', 'https://notes-automate.com/posts/obsidian-local-rest-api-configuration-script-tool/'],
      ['Best Templater Snippet Collections for Obsidian', 'https://notes-automate.com/posts/best-templater-snippet-collections-for-obsidian-2026/'],
    ],
  },
  {
    name: 'PKM Insights',
    url: 'https://pkm.notes-automate.com',
    description: 'Personal knowledge management, Zettelkasten, academic research workflows, and digital garden publishing.',
    links: [
      ['Digital Garden Hosting Platforms for Obsidian Users', 'https://pkm.notes-automate.com/posts/digital-garden-hosting-platforms-for-obsidian-users/'],
      ['Obsidian Dataview Templates for Academic Researchers', 'https://pkm.notes-automate.com/posts/obsidian-dataview-templates-for-academic-researchers-2026/'],
      ['Best Self Hosted PKM Tools for Data Privacy', 'https://pkm.notes-automate.com/posts/best-self-hosted-pkm-tools-for-data-privacy/'],
    ],
  },
];
---
<BaseLayout
  title="ToolRoute AI"
  description="ToolRoute AI is an independent guide network for AI tools, note automation, PKM workflows, and home office gear."
  canonicalURL="https://toolrouteai.com/"
>
  <div class="brand-home">
    <section class="hero">
      <p class="eyebrow">Independent guides for tool decisions</p>
      <h1>ToolRoute AI</h1>
      <p>ToolRoute AI is a small independent publishing network for people who need practical software and workspace decisions, not hype. We cover AI tools, automation workflows, note systems, personal knowledge management, and the desk equipment that makes daily work sustainable.</p>
    </section>

    <section class="mission">
      <h2>Why this network exists</h2>
      <p>Most tool searches are noisy. A single query can return sponsored roundups, shallow listicles, outdated product screenshots, and confident claims that ignore privacy, workflow fit, maintenance cost, or the small details that matter after a week of use. ToolRoute AI was created to slow that process down and make comparisons more useful.</p>
      <p>Our approach is practical: explain who a tool is for, where it fails, what setup work is required, and what adjacent alternatives are worth considering. AI assists our research and drafting workflow, but articles are reviewed before publication for structure, obvious factual problems, affiliate disclosure, and whether the page actually helps a reader make a decision.</p>
    </section>

    <section class="network">
      <h2>Our sites</h2>
      <div class="site-grid">
        {sections.map(section => (
          <article class="site-card">
            <h3><a href={section.url}>{section.name}</a></h3>
            <p>{section.description}</p>
            <h4>Start here</h4>
            <ul>
              {section.links.map(([title, href]) => (
                <li><a href={href}>{title}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="trust">
      <h2>Editorial trust signals</h2>
      <div class="trust-grid">
        <div>
          <h3>Human accountability</h3>
          <p>Every site has visible author pages, contact information, privacy terms, and editorial standards. Corrections can be sent to <a href="mailto:hello@toolrouteai.com">hello@toolrouteai.com</a>.</p>
        </div>
        <div>
          <h3>Reader-first monetization</h3>
          <p>Ads and affiliate links may support the work, but they do not buy rankings or remove trade-offs. We publish disclosures and keep recommendations grounded in reader use cases.</p>
        </div>
        <div>
          <h3>Reviewable process</h3>
          <p>Our <a href="/editorial-policy/">editorial policy</a> explains how AI assistance, human review, source checks, and updates fit together.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .brand-home { max-width: 1120px; margin: 0 auto; padding: 1rem 1rem 4rem; }
  .hero { padding: 4rem 0 3rem; border-bottom: 1px solid var(--line); }
  .hero h1 { font-size: clamp(3rem, 8vw, 5.6rem); margin-bottom: 1rem; }
  .hero p:not(.eyebrow) { max-width: 780px; color: var(--muted); font-size: 1.18rem; }
  .mission, .network, .trust { padding: 3rem 0 0; }
  .mission p { max-width: 820px; color: #374151; }
  .site-grid, .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(245px, 1fr)); gap: 1rem; }
  .site-card, .trust-grid > div { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 1.25rem; }
  .site-card h3, .trust-grid h3 { font-size: 1.15rem; }
  .site-card h4 { margin: 1.25rem 0 .5rem; font-size: .92rem; text-transform: uppercase; color: var(--muted); }
  .site-card ul { padding-left: 1.1rem; }
  .site-card li { margin-bottom: .5rem; }
  a { color: var(--accent); }
</style>
