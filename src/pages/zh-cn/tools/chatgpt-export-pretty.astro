  limitationTitle: '导入限制',
  limitationBody: '浏览器会阻止网页直接读取 chatgpt.com，所以请手动粘贴对话。HTML 清洗器会在渲染前移除脚本、事件处理器、表单和危险属性。',
  relatedTitle: '相关 AI 工作流指南',
  actionLabel: '工具操作',
  summaryLabel: '文档汇总',
  defaultDocumentTitle: 'ChatGPT 对话整理稿',
  defaultDocumentAuthor: 'AI Tools Pro',
  pdfFailed: 'PDF 导出失败',
