---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChatGptExportPretty from '../../../components/ChatGptExportPretty.astro';

const title = 'ChatGPT 对话美化导出：粘贴、清洗并导出 PDF | AI Tools Pro 中文';
const description = '手动粘贴 ChatGPT Markdown 或复制出来的聊天 HTML，在浏览器本地美化渲染、复制清洗后的 HTML，并导出 PDF。';
const canonicalURL = 'https://toolrouteai.com/zh-cn/tools/chatgpt-export-pretty/';
const relatedLinks = [
  {
    title: '低预算独立创业者的最佳 AI 工具',
    href: '/zh-cn/posts/best-ai-tools-for-solopreneurs-on-a-budget/',
    description: '先把 AI 工具栈控制住，再决定哪些工具值得长期付费。',
  },
  {
    title: '如何用 Claude API 做内容生产',
    href: '/zh-cn/posts/how-to-use-claude-api-for-content/',
    description: '把模型输出变成可复用内容流程，同时保留人工审核环节。',
  },
  {
    title: '2026 年最佳 AI 写作工具',
    href: '/zh-cn/posts/best-ai-writing-tools-2026/',
    description: '在固定导出和发布流程前，先对比主流 AI 写作工具。',
