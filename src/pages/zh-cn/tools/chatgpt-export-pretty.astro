  inputTitle: '粘贴对话',
  inputLabel: '只能手动粘贴。浏览器 CORS 会阻止直接读取 chatgpt.com 对话内容，所以这里不做抓取。',
  inputPlaceholder: '把 Markdown、复制出来的 ChatGPT HTML，或混合格式的对话粘贴到这里...',
  formatLabel: '输入格式',
  formatAuto: '自动识别',
  formatMarkdown: 'Markdown',
  formatHtml: '复制的 HTML',
  documentTitle: '文档标题',
  documentAuthor: '文档标签',
  sample: '载入示例',
  render: '渲染预览',
  exportPdf: '导出 PDF',
  copyHtml: '复制清洗 HTML',
  clear: '清空',
  copied: '清洗 HTML 已复制',
  rendered: '预览已渲染',
  pdfReady: 'PDF 导出已启动',
