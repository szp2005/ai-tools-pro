  url: canonicalURL,
  description,
  inLanguage: 'zh-cn',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  featureList: [
    '手动粘贴 ChatGPT Markdown 或复制出来的聊天 HTML',
    '渲染干净的文档预览',
    '清除脚本、事件处理器和危险属性',
