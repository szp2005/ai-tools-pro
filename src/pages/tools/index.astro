---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    title: 'Token + Cost Calculator',
    href: '/tools/token-cost-calculator/',
    description: 'Estimate GPT, Claude, and Gemini token counts and API costs from one prompt.',
  },
  {
    title: 'AI Subscription Tracker',
    href: '/tools/ai-subscription-tracker/',
    description: 'Track recurring AI software spend, renewal alerts, and CSV backups locally in your browser.',
  },
];
---

<BaseLayout
  title="Free AI Tools | AI Tools Pro"
  description="Free local browser tools for AI power users, including token cost estimation and AI subscription tracking."
  canonicalURL="https://ai.toolrouteai.com/tools/"
>
  <section class="tools-index">
    <h1>Free AI Tools</h1>
    <p>Small browser-native utilities for people who need to control AI costs before they become a surprise.</p>
    <div class="tools-grid">
      {tools.map((tool) => (
        <article>
          <h2><a href={tool.href}>{tool.title}</a></h2>
          <p>{tool.description}</p>
          <a class="tool-link" href={tool.href}>Open tool</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tools-index { max-width: 960px; margin: 0 auto; padding: 4rem 1rem; }
  .tools-index h1 { font-size: clamp(2.5rem, 7vw, 5rem); }
  .tools-index > p { max-width: 720px; color: var(--muted); font-size: 1.15rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; margin-top: 2rem; }
  .tools-grid article { border: 1px solid var(--line); border-radius: 8px; background: var(--panel); padding: 1.25rem; }
  .tools-grid h2 { font-size: 1.25rem; }
  .tools-grid p { color: var(--muted); }
  .tool-link { display: inline-flex; background: var(--accent); color: #fff; padding: .7rem .9rem; border-radius: 8px; text-decoration: none; font-weight: 800; }
</style>
